{
  "name": "study_cards",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run report && npm run validate && node scripts/rebuild_index.js && npx http-server -p 3000 -c-1",
    "build": "node scripts/rebuild_index.js",

    "validate": "npm run validate:common-shared",
    "validate:common-shared": "node scripts/build/validate_common_shared.js",

    "report": "npm run report:duplicated-keys && npm run report:missing-related && npm run report:collection-contract",
    "report:duplicated-keys": "node scripts/report_duplicated_keys.mjs",
    "report:missing-related": "node scripts/report_missing_related_collection_data.mjs",
    "report:collection-contract": "node scripts/report_collection_contract.mjs",
    
    "imports:process": "node scripts/process_collection_import.mjs",
    "revisions:process": "node scripts/process_collection_revisions.mjs",
    "zip:backup": "node scripts/backup_zips.js --clean --openDistFolder",
    "zip:applyUpdatedZips": "node scripts/apply_updated_zips.js"
  },
